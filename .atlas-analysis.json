  "keyFeatures": [
    "SOA architecture with Database-per-Service isolation pattern",
    "Centralized Spring Cloud Gateway routing all traffic on port 8080",
    "Netflix Eureka service discovery for dynamic service registration",
    "SAGA pattern with logical rollback for distributed POS transactions",
    "Dual database strategy: PostgreSQL for transactional data, MongoDB for product catalog",
    "Two React frontends: web storefront (frontend-web) and physical POS terminal (frontend-pos)",
    "OpenAPI/Swagger UI auto-generated at /swagger-ui.html on each service",
    "Docker Compose infrastructure bootstrap for local development"
  ],
  "publicApiSurface": [
    "GET  /api/v1/inventario/{productoId}/stock — query available stock for a product",
    "POST /api/v1/inventario/{productoId}/descontar?cantidad={n} — decrement stock",
    "GET/POST /api/v1/catalogo/** — catalog product management (MongoDB-backed)",
    "POST /api/v1/ventas-pos/** — POS sale transaction orchestrator with SAGA rollback",
    "GET  /actuator/health — API Gateway health check",
    "GET  /actuator/info — API Gateway build info",
    "Eureka Dashboard — http://localhost:8761",
    "Swagger UI — http://localhost:{port}/swagger-ui.html (per service)"
  ]
}
